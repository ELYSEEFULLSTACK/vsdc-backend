# Backend .env file

# Server Configuration
PORT=5000

# Firebase Admin SDK
# For Railway, this is ignored - use FIREBASE_SERVICE_ACCOUNT env var instead
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# RRA VSDC Environment (test or production)
RRA_ENVIRONMENT=test  # Change to "production" when approved

# RRA URLs
RRA_TEST_URL=https://sedsandbox.rra.gov.rw
RRA_PRODUCTION_URL=https://api-ebm.rra.gov.rw

# ⭐ YOUR TIN - Update this when you go live!
YOUR_TIN=999991130  # ← Change this to your REAL TIN (e.g., 123456789) when approved

# Default Branch ID
DEFAULT_BHF_ID=00

# Frontend URLs for CORS (add your deployed frontend URLs here)
FRONTEND_LOCAL=http://localhost:3000
FRONTEND_FIREBASE=https://n413.web.app
FRONTEND_FIREBASE_ALT=https://n413.firebaseapp.com